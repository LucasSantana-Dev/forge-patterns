#!/usr/bin/env sh
set -eu

echo "⚙️  [test-autogen] pre-commit (phase0 warn)"
TENANT_ID="${FORGE_TENANT_ID:-}"
TENANT_PROFILE_REF="${FORGE_TENANT_PROFILE_REF:-}"

if [ -z "$TENANT_ID" ] || [ -z "$TENANT_PROFILE_REF" ]; then
  echo "⚠️  FORGE_TENANT_ID/FORGE_TENANT_PROFILE_REF ausentes; pulando test-autogen (warn-only)."
  exit 0
fi

if ! npx forge-ai-init test-autogen --staged --write --json --tenant "$TENANT_ID" --tenant-profile-ref "$TENANT_PROFILE_REF"; then
  echo "⚠️  test-autogen falhou ou indisponivel; commit segue em modo warn."
fi
exit 0
